# ==============================================================================
# .gitignore — Node / Electron desktop app.
# ==============================================================================

# --- Secrets -----------------------------------------------------------------
# A real .env is machine-local and never committed. The negation keeps the
# committed example (the actual contract) tracked despite the pattern above.
.env
.env.*
!.env.example
*.local

# --- OS junk -----------------------------------------------------------------
.DS_Store
Thumbs.db
Desktop.ini

# --- Editor / IDE directories ------------------------------------------------
.vscode/
.idea/
*.swp
*~

# --- Node dependencies + build output ----------------------------------------
node_modules/
# electron-vite build output (main/preload/renderer) and electron-builder
# packaged installers.
out/
dist/
*.tsbuildinfo
.eslintcache

# --- Test / coverage output --------------------------------------------------
coverage/
.nyc_output/

# --- Playwright artifacts ----------------------------------------------------
/test-results/
/playwright-report/
/blob-report/
/.playwright/
/playwright/.cache/

# --- Docs site (MkDocs Material, machinery in website/) -----------------------
# The uv-managed virtualenv and the generated site are build artifacts, never
# committed. website/pyproject.toml + website/uv.lock ARE committed (the pinned
# toolchain). The Pages workflow rebuilds website/site/ from scratch.
website/.venv/
website/site/
.cache/

# --- Local data --------------------------------------------------------------
# Real data never enters git. Exports, dumps, and fixtures derived from a live
# session belong on disk only.
data/

# --- Agent scratch -----------------------------------------------------------
# Claude Code drops per-agent git worktrees here during multi-agent sessions.
.claude/worktrees/
